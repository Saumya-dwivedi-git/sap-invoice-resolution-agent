{
  "name": "sap-invoice-resolution-agent",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/audit-logging": ">=0",
    "@cap-js/hana": "^2",
    "@sap-cloud-sdk/connectivity": "^4.7.0",
    "@sap-cloud-sdk/http-client": "^4.7.0",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.17.0",
    "mbt": "^1.2.49",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-invoiceworklist": "cds watch --open invoice.agent.invoiceworklist/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy sap-invoice-resolution-agent --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "private": true,
  "cds": {
    "requires": {
      "[production]": {
        "auth": "xsuaa",
        "connectivity": true
      },
      "destinations": true,
      "html5-repo": true,
      "application-logging": true
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/invoiceworklist"
  ]
}
