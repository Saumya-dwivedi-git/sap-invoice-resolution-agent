{
  "welcomeFile": "/invoiceagentinvoiceworklist/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/invoice-agent/(.*)$",
      "target": "/invoice-agent/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": true
    },
    {
      "source": "^/(.*)$",
      "target": "$1",
      "service": "html5-apps-repo-rt",
      "authenticationType": "xsuaa"
    }
  ]
}
